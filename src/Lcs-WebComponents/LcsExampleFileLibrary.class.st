	background-color: #f5f5f5;
	color: var(--text-color);
	padding: .15rem .5rem;
	min-height: 40px;
	border-radius: 4px;
	outline: none;
	border: none;
	line-height: 1.15;
	box-shadow: 0px 10px 20px -18px;
	
	& :focus {
		border-bottom: 2px solid #5b5fc7;
		border-radius: 4px 4px 2px 2px;
		}
	& :hover {
		outline: 13px solid lightgrey;
		}
	}

.select {
	max-width: 190px;
	background-color: var(--tertiary-background-color);
	color: var(--text-color);
	padding: .15rem .5rem;
	min-height: 40px;
	border-radius: 4px;
	outline: none;
	border: none;
	line-height: 1.15;
	box-shadow: 0px 10px 20px -18px;
	
	& :focus {
		border-bottom: 2px solid #5b5fc7;
		border-radius: 4px 4px 2px 2px;
		}
	& :hover {
		outline: 13px solid lightgrey;
		}
	}
	
.inputLabel {
	max-width: 190px;
	/* background-color: #f5f5f5; */
	color: var(-text-color-light);
	padding: .15rem .5rem;
	min-height: 40px;
	border-radius: 4px;
	outline: none;
	border: none;
	line-height: 1.15;
	box-shadow: 0px 10px 20px -18px;
	align-content: center;
	}

section {
	display: grid;
	grid-template-columns: 200px 200px;
	gap: 0.25rem;
	}
