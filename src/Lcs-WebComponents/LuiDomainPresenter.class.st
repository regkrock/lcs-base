Class {
	#name : 'LuiDomainPresenter',
	#superclass : 'LuiPresenter',
	#instVars : [
		'domain'
	],
	#category : 'Lcs-WebComponents-Core',
	#package : 'Lcs-WebComponents',
	#tag : 'Core'
}

{ #category : 'accessing' }
LuiDomainPresenter >> domain [
	^ domain
]

{ #category : 'accessing' }
LuiDomainPresenter >> domain: anObject [
	domain := anObject
]
