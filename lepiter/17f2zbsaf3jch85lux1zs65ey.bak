					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-05-02T12:11:34.309227-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "dvi2yw/qRj+GvAsdTrGaLA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "The top right corner of the SEAS will show the status of the user. \n- When the SEAS web pages are  openned, a 'Log In' button will be displayed in the top right corner.\n- When the user is loged in, the 'Log In' button will be replaced with a button displayig the registered user's name, followed by 'Logout' button. \n- When the registered user logs out, the display will return to showing only the login button."
			},
			{
				"__type" : "textSnippet",
