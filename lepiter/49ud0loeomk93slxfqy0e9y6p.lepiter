					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-05-27T11:55:19.061874-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "TR+eKONvRumUNWlYpaDhGQ=="
				},
				"code" : "builder := LcsComponentAttributesSubclassAndInstallationBuilder new.\rbuilder\r\tclassPrefix: 'Lui';\r\tclassRootName: 'Heading';\r\ttargetComponentClassName: LuiHeading name;\r\tinstallNewClassesInPackageNamed: 'Lcs-WebComponents' tag: 'Core'.\r\rbuilder buildJobSteps.\r^ builder"
			},
