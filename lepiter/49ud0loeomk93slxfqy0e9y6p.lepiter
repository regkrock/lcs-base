					"uidString" : "2l/SgUimT22JMzox4+iLzA=="
				},
				"code" : "\tbuilderJob := LcsCompenentAttributeBuilderJob new.\r\tbuilderJob\r\t\tclassPrefix: 'Lui';\r\t\tcreateForRootName: 'HeadingLevel';\r\t\t\"attributeName: 'level';\"\r\t\ttagAttributeSetterSelector: #level:; \r\t\tinstallNewClassesInPackageNamed: 'Lcs-WebComponents' tag: 'Core';\r\t\t\" componentAttributesClassName: LuiComponentAttributes name; \"\r\t\tcomponentAttributesClassName: 'LuiHeadingAttributes';\r\t\tcomponentClassName: LuiHeading name. \r\tbuilderJob buildJobSteps.\r\t^ builderJob"
