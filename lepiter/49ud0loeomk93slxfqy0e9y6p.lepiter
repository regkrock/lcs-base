					"uidString" : "VDk7ag+aSee8rFTw710mbw=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "1) Decide if a subclass of LuiComponentAttributes needs to be created in order to limit scope issues it everything is implemented in the superclass.\n\nIn this example, a heading level is being added. However its scope is limited to {{gtClass:name=LuiHeading}} . To facilitate this, a new subclass of {{gtClass:name=LuiComponentAttributes}} is created. \n\nSo LuiHeadingAttributes is created and installed in LuiHeading."
			},
			{
				"__type" : "pharoSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [ ]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-05-27T11:27:53.955459-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-05-27T11:55:19.061874-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "TR+eKONvRumUNWlYpaDhGQ=="
				},
				"code" : "builder := LcsComponentAttributesSubclassAndInstallationBuilder new.\rbuilder\r\tclassPrefix: 'Lui';\r\tclassRootName: 'Heading';\r\ttargetComponentClassName: LuiHeading name;\r\tinstallNewClassesInPackageNamed: 'Lcs-WebComponents' tag: 'Core'.\r\rbuilder buildJobSteps.\r^ builder"
			},
			{
				"__type" : "textSnippet",
				"children" : {
