							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-05-02T10:54:37.766142-04:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "nt50kePiQjqu4vckqSpWNQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "Both use cases and stories are useful in different ways. Both are elements of the architectural process, but you cannot even think about implementation until that architecture, or a portion of it, is at least roughed out in your head. A skilled programmer can work on both simultaneously."
						}
					]
				},
