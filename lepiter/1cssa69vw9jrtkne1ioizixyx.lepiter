							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "1uQobvrRDQC2eVg9AqAYSw=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "In a domain class, there is a class instance variable, {{gtMethod:LcsDomainObject>>slotModel}} which has the responsibility of refrencing the class' slot model ({{gtClass:name=LcsSlotModel}}). The slot model is populated from the class side slot definition methods in the domian object. "
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2024-04-08T13:04:16.822312-04:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2024-06-07T07:30:35.56353-04:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "s0lZiPrRDQC/qK5rAqAYSw=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "{{gtMethod:name=LxxPrototypeSystem class>>personsSlotDefinition}}"
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
