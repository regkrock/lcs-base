							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-04-30T13:37:30.155591-04:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-04-30T15:40:38.25046-04:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "qsTqxeOLSwuTei9zDvHMew=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "In Pharo Smalltalk the instance variables have been implemented using a {{gtClass:name=Slot}} class.  This has been implemented in the core of the language.\n\nHowever all other Smalltalks, including GemStone, have not emplemented this feature. Therefore it is necessary to implement a domain level slot which can be ported between Pharo and GemStone."
						}
					]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-30T15:40:30.348319-04:00"
					}
				},
