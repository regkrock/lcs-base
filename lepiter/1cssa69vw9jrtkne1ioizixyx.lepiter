					"emailString" : "<unknown>"
				},
				"editTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-30T15:40:30.348319-04:00"
					}
				},
				"uid" : {
					"__type" : "uid",
					"uidString" : "xU0ePQ+cS5ir+fVMNLgpcA=="
				},
				"paragraphStyle" : {
					"__type" : "textStyle"
				},
				"string" : "**Slot Implementation In Various Smalltalks**"
			},
			{
				"__type" : "textSnippet",
				"children" : {
					"__type" : "snippets",
					"items" : [
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-04-30T15:00:23.176112-04:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-04-30T15:42:13.247959-04:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "GtVT7e/HRgmytIWMBzC5EA=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "In this framework a **slot** is a first class object which encapsulates the accessing, read and write, to an instance variable of a class. They are also only used in application specific classes. Hence it is named a 'Domain Slot' ({{gtClass:name=LcsDomainSlot}})."
						},
						{
							"__type" : "textSnippet",
							"children" : {
								"__type" : "snippets",
								"items" : [ ]
							},
							"createEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"createTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-04-30T15:21:39.671484-04:00"
								}
							},
							"editEmail" : {
								"__type" : "email",
								"emailString" : "<unknown>"
							},
							"editTime" : {
								"__type" : "time",
								"time" : {
									"__type" : "dateAndTime",
									"dateAndTimeString" : "2026-04-30T15:21:39.671484-04:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "IojW/YgNTaewn5Z64IgNCw=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "So to disambiguate , the slots used in the is framework inherit from  {{gtClass:name=LcsDomainSlot}}.  Only domain application classes,  {{gtClass:name=LcsBaseDomainObject}} and its subclasses,  have 'domain slots'. All other classes are considered to be Smalltalk classes. Access to the instance variable is accomplished used the protocol of the base Smalltalk implementation. This includes classes which are part of the base application development environment and application related classes that do not inherit from {{gtClass:name=LcsBaseDomainObject}}.  Examples include  {{gtClass:name=LcsObject}} and {{gtClass:name=LcsUmlModel}}."
						}
					]
				},
