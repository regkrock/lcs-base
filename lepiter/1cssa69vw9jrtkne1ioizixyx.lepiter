									"dateAndTimeString" : "2026-04-30T15:41:59.524713-04:00"
								}
							},
							"uid" : {
								"__type" : "uid",
								"uidString" : "/XQu3kaDSGycwVzYZbaGfQ=="
							},
							"paragraphStyle" : {
								"__type" : "textStyle"
							},
							"string" : "A slot has several meanings depending on context:\n1) A *slot* is another word for intance variable. An instance variable takes up a slot of memory.\n2) A slot can also refer to an object whose responsiblity is to encapsulate the behaviour associated with an instance variable. This includes accessing the contents of the instance variable.\n\nThe later concept was introduced by Marvin Minksy and colleagues in his work on Frames and Slots at MIT. Basically, a Frame is composed on one to may slots which help describe the Frame. This work was expressed in [LISP](https://en.wikipedia.org/wiki/Lisp_(programming_language))  related languges such as [CLOS](https://en.wikipedia.org/wiki/Common_Lisp_Object_System)."
						}
					]
				},
				"createEmail" : {
					"__type" : "email",
					"emailString" : "<unknown>"
				},
				"createTime" : {
					"__type" : "time",
					"time" : {
						"__type" : "dateAndTime",
						"dateAndTimeString" : "2026-04-30T15:41:48.377253-04:00"
					}
				},
				"editEmail" : {
					"__type" : "email",
